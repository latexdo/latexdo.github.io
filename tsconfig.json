{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2021"],
    "strict": true,
    "rootDir": "src",
    "outDir": "assets",
    "declaration": false,
    "sourceMap": false,
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
