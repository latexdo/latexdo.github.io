{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "latexdo-org",
  "compatibility_date": "2026-06-27",
  "assets": {
    "directory": ".",
    "not_found_handling": "404-page",
    "exclude": [
      "node_modules/**",
      ".git/**",
      ".github/**",
      "src/**",
      "package*.json",
      "tsconfig.json",
      "wrangler.jsonc",
      "README.md",
      "LICENSE"
    ]
  }
}
